{
  "name": "ai-supreme-proxmox-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Orchestrator and Sentinel Bridge for SpartanAI ProxMox Server",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "orch": "tsx agent_cli.ts",
    "test": "playwright test",
    "test:universal": "npx playwright test tests/universal_e2e",
    "unbox": "node scripts/unbox_protocol.cjs",
    "purity": "node scripts/universal_debug_purity.js",
    "shell": "electron sovereign_shell.js",
    "build:bundle": "esbuild src/server.ts --bundle --minify --platform=node --target=node20 --format=esm --outfile=dist/server.js --external:sqlite3 --external:canvas --external:node:sqlite",
    "build": "npm run build:bundle"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "msgpack-lite": "^0.1.26",
    "proxmox-api": "^1.1.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "electron": "^42.3.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
